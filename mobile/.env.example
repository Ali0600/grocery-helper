# Base URL of the backend API.
# - iOS simulator:      http://localhost:8000
# - Android emulator:   http://10.0.2.2:8000
# - Physical phone:     http://<your-computer-LAN-IP>:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Postal code the app starts on. Set your own here (this file is for local dev);
# the committed default is a neutral central-Berlin 10115.
EXPO_PUBLIC_DEFAULT_PLZ=10115

# Optional: must match the backend's ADMIN_TOKEN for the Options → "Wipe & re-scrape"
# action once that token is set (sent as an X-Admin-Token header). Inlined into the
# public JS bundle, so it's a light guard, not a real secret.
# EXPO_PUBLIC_ADMIN_TOKEN=change-me
