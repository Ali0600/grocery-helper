; Pin the public npm registry. We use only public packages, but Dependabot's
; automatic-github-packages-auth injects npm.pkg.github.com as a "private registry"
; and then aborts npm file-fetching ("Private npm registries require either a .npmrc
; file in your repository, or explicit scope/replaces-base configuration") — having
; this .npmrc satisfies that check so the weekly npm update can run. No secrets here.
registry=https://registry.npmjs.org/
