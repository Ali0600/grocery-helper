# Local dev uses SQLite by default — no setup needed. Copy to .env to override.
DATABASE_URL=sqlite:///./grocery.db
# For Postgres (Docker / PaaS):
# DATABASE_URL=postgresql+psycopg2://grocery:grocery@db:5432/grocery

DEFAULT_PLZ=10115
CORS_ORIGINS=*

# Root log level (DEBUG/INFO/WARNING/...). Scraper/locator failures log a warning.
LOG_LEVEL=INFO
# Optional: enable Sentry error tracking by setting a DSN (no-op when unset).
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Optional: when set, POST /api/reset and /api/recategorize require this token
# (sent as an X-Admin-Token header). Leave unset for open local dev.
# ADMIN_TOKEN=change-me
